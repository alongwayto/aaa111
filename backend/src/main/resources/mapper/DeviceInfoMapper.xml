<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.equipment.mapper.DeviceInfoMapper">

    <resultMap id="DeviceVOMap" type="com.campus.equipment.vo.DeviceVO">
        <id column="id" property="id"/>
        <result column="device_code" property="deviceCode"/>
        <result column="device_name" property="deviceName"/>
        <result column="category_id" property="categoryId"/>
        <result column="category_name" property="categoryName"/>
        <result column="location_id" property="locationId"/>
        <result column="location_name" property="locationName"/>
        <result column="brand" property="brand"/>
        <result column="model" property="model"/>
        <result column="serial_number" property="serialNumber"/>
        <result column="purchase_date" property="purchaseDate"/>
        <result column="purchase_price" property="purchasePrice"/>
        <result column="warranty_date" property="warrantyDate"/>
        <result column="status" property="status"/>
        <result column="online_status" property="onlineStatus"/>
        <result column="tags" property="tags"/>
        <result column="description" property="description"/>
        <result column="image_url" property="imageUrl"/>
        <result column="responsible_person" property="responsiblePerson"/>
        <result column="responsible_phone" property="responsiblePhone"/>
        <result column="last_maintain_time" property="lastMaintainTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectDevicePage" resultMap="DeviceVOMap">
        SELECT d.*,
               dc.name AS category_name,
               dl.full_address AS location_name
        FROM device_info d
        LEFT JOIN device_category dc ON d.category_id = dc.id
        LEFT JOIN device_location dl ON d.location_id = dl.id
        WHERE d.deleted = 0
        <if test="deviceCode != null and deviceCode != ''">
            AND d.device_code LIKE CONCAT('%', #{deviceCode}, '%')
        </if>
        <if test="deviceName != null and deviceName != ''">
            AND d.device_name LIKE CONCAT('%', #{deviceName}, '%')
        </if>
        <if test="categoryId != null">
            AND d.category_id = #{categoryId}
        </if>
        <if test="locationId != null">
            AND d.location_id = #{locationId}
        </if>
        <if test="status != null">
            AND d.status = #{status}
        </if>
        <if test="onlineStatus != null">
            AND d.online_status = #{onlineStatus}
        </if>
        ORDER BY d.create_time DESC
    </select>

</mapper>
